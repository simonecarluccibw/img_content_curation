 def summarize_api_response(api_response: Dict, limit: int = 1200) -> str:
     try:
         serialized = json.dumps(api_response, ensure_ascii=False)
     except Exception:
         serialized = str(api_response)
     return shorten_text(serialized, limit=limit)
 
 
+def read_http_error_body(exc: urllib.error.HTTPError, limit: int = 2000) -> str:
+    try:
+        body = exc.read()
+    except Exception:
+        return ""
+    if isinstance(body, bytes):
+        text = body.decode("utf-8", errors="replace")
+    else:
+        text = str(body)
+    return shorten_text(text, limit=limit)
+
+
+def format_http_error(exc: urllib.error.HTTPError, body: str) -> str:
+    detail = f"HTTP Error {exc.code}: {exc.reason}"
+    if body:
+        return f"{detail} | response body: {body}"
+    return detail
+
+
 def build_thinking_config(section: Dict) -> Dict:
     budget = section.get("thinking_budget", 0)
     return {"thinkingBudget": budget}
